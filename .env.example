# Cloudflare SMTP Forge - Environment Variables
# Copy this file to .env.local for local development

# Cloudflare API Token (required for production)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Use template: Edit Cloudflare Workers
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID (required for production)
# Find at: https://dash.cloudflare.com/ > Overview > Account ID
CLOUDFLARE_ACCOUNT_ID=

# D1 Database ID (required - from wrangler d1 create output)
D1_DATABASE_ID=

# Application Environment
APP_ENV=development