{
  "name": "smtp-forge",
  "main": "dist/server/server.js",
  "compatibility_date": "2024-04-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "d1_databases": [{
    "binding": "DB",
    "database_name": "smtp-forge-db",
    "database_id": "b7ad7dfc-dee4-4b67-b291-814f30df99e5",
    "migrations_dir": "migrations"
  }],
  "vars": {
    "APP_ENV": "production"
  },
  "assets": {
    "directory": "dist/client/assets"
  },
  "placement": {
    "mode": "smart"
  }
}
